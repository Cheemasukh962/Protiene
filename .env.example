GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY
POSTGRES_DSN=postgresql://postgres:YOUR_PASSWORD@localhost:5432/postgres
# Required for login/session cookies. Use a long random value.
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
COOKIE_NAME=dprotein_access_token
# Local defaults:
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
CORS_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,http://127.0.0.1:5173,http://localhost:5173

# Production (Railway + Vercel) guidance:
# COOKIE_SECURE=true
# COOKIE_SAMESITE=none
# CORS_ALLOWED_ORIGINS=https://YOUR_FRONTEND.vercel.app,http://localhost:5173
